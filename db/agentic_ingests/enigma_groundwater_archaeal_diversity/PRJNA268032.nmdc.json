  "study_set": [
    {
      "id": "nmdc:sty-99-7affccee",
      "type": "nmdc:Study",
      "name": "Reconstruction of novel archaeal genomes from metagenomic groundwater sample",
      "description": "We used genome-resolved metagenomic analyses to investigate the diversity, genomes sizes, metabolic capacities and potential roles of Archaea in terrestrial subsurface biogeochemical cycles. We sequenced DNA from complex sediment and planktonic consortia from an aquifer adjacent to the Colorado River, USA, and reconstructed the first complete genomes for Archaea using cultivation-independent methods. We resolved two new phyla within a major, apparently deep-branching group of phyla (a superphylum). The organisms have small genomes and metabolic predictions indicate that their primary contributions to Earth’s biogeochemical cycles involve carbon and hydrogen metabolism, probably associated with symbiotic and/or fermentation-based lifestyles.",
      "study_category": "research_study",
      "insdc_bioproject_identifiers": [
        "insdc.sra:PRJNA268032"
      ],
      "provenance_metadata": {
        "type": "nmdc:ProvenanceMetadata",
        "add_date": "2026-06-19T23:33:01.731583+00:00",
        "git_url": "https://github.com/microbiomedata/nmdc-ingest-agent",
        "mod_date": "2026-06-19T23:33:01.731583+00:00",
        "version": "0.1.0",
        "source_system_of_record": "NCBI"
      },
      "title": "Reconstruction of novel archaeal genomes from metagenomic groundwater sample"
    }
  ],
