{
  "study": {
    "id": "nmdc:sty-99-8744d904",
    "name": "",
    "title": "Molecular basis of anthracnose resistance in sorghum",
    "description": "This study was aimed at identifying the molecular basis of the resistance of select sorghum accessions against the pathogenic fungus Colletotrichum sublineola, the causal agent of anthracnose. An RNA-seq experiment was conducted to monitor changes in gene expression in seedlings during the initial days after infection, relative to mock-inoculated plants.",
    "publications": []
  },
